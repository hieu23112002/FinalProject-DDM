# Frontend
NEXT_PUBLIC_API_URL=/api

# MLFlow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin

# PostgreSQL Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
