# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# Worker
DATABASE_URL=postgresql://user:password@db:5432/churn_db
REDIS_URL=redis://redis:6379/0
